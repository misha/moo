{
  "chat.disableAIFeatures": true,
  "editor.indentSize": 2,
  "editor.insertSpaces": true,
  "editor.detectIndentation": false,
  "editor.formatOnSave": true,
  "editor.defaultColorDecorators": "always",
  "files.insertFinalNewline": true,
  "files.exclude": {
    "**/.git": true,
    "**/*.g.dart": true,
    "**/*.freezed.dart": true,
  },
  "dart.lineLength": 120,
  "cSpell.enabled": true,
  "cSpell.words": [
    "BIODATA",
    "chebyshev",
    "decoratable",
    "HIGHSCORE",
    "Hitbox",
    "lerps",
    "LTWH",
    "misha",
    "Noto",
    "pprotocol",
    "Procgen",
    "pstate",
    "ptransition",
    "pubspec",
    "riverpod",
    "Scanline",
    "Scanlines",
    "Shapeforms",
    "SOLITERMAN",
    "STANDUPS",
    "tearoffs",
    "typewritertext",
    "undecorate",
    "undim",
    "unwatch",
    "widgetbook",
    "yafsm"
  ],
  "cSpell.ignorePaths": [
    "LICENSE",
    "pubspec.lock",
    "pubspec.yaml",
    "vscode-extension",
    ".git/{info,lfs,logs,refs,objects}/**",
    ".git/{index,*refs,*HEAD}",
    ".gitignore",
    ".github/",
    ".vscode/",
  ],
  "launch": {
    "version": "0.2.0",
    "configurations": [
      {
        "name": "Game",
        "request": "launch",
        "type": "dart",
        "program": "lib/main.dart",
      },
      {
        "name": "Widgetbook",
        "request": "launch",
        "type": "dart",
        "program": "test/widgetbook/widgetbook.dart",
      },
    ],
  },
}
